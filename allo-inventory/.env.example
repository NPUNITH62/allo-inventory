# Database (Supabase / Neon / Railway — hosted Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Redis (Upstash recommended for Vercel)
# Upstash provides REDIS_URL in the format: rediss://:<password>@<host>:<port>
REDIS_URL="rediss://:password@hostname:6379"

# Reservation window in minutes (default: 10)
RESERVATION_MINUTES=10

# Vercel Cron secret (set this in Vercel dashboard too)
CRON_SECRET="a-long-random-secret-string"
